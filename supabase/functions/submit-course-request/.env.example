# Secrets for the submit-course-request Edge Function.
# Supabase Edge Functions don't read this file at runtime — it documents
# what to set as secrets via the Dashboard (Project Settings > Edge
# Functions > Secrets) or `supabase secrets set`. Never commit real values.

# amoCRM account subdomain, e.g. "yourcompany" for yourcompany.amocrm.ru.
AMOCRM_SUBDOMAIN=

# Long-lived API token generated from the private integration's card in
# amoCRM (Settings > Integrations > <your integration> > "Long-lived
# token"). Used as a static Bearer token — no OAuth refresh flow needed
# for this token type. Never expose it to the frontend.
AMOCRM_ACCESS_TOKEN=

# Human-readable pipeline/stage names (not numeric IDs) so the integration
# is portable across amoCRM accounts. The function resolves these to the
# actual pipeline_id/status_id via GET /api/v4/leads/pipelines at request
# time, rather than a hardcoded account-specific ID.
AMOCRM_PIPELINE_NAME=
AMOCRM_STAGE_NAME=

# Resend (https://resend.com) is already used elsewhere in this repo for
# transactional email (see supabase/functions/submit-lead). Reused here to
# notify the team when a new course request comes in.
RESEND_API_KEY=
NOTIFY_FROM_EMAIL=
# Comma-separated list of recipient addresses.
NOTIFY_EMAILS=
